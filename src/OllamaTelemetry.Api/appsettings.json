{
  "Telemetry": {
    "RefreshAfterSeconds": 5,
    "StaleAfterSeconds": 30,
    "Storage": {
      "ConnectionString": "Data Source=data/telemetry.db;Mode=ReadWriteCreate;Cache=Shared;Pooling=True",
      "RetentionDays": 14,
      "CleanupIntervalMinutes": 60
    },
    "Persistence": {
      "MinimumDeltaCelsius": 0.5,
      "ForceWriteIntervalSeconds": 60
    },
    "Source": {
      "RequestTimeoutSeconds": 4
    },
    "Machines": [
      {
        "MachineId": "snd-host",
        "DisplayName": "SND-HOST",
        "SourceType": "HostAgent",
        "Endpoint": "http://192.168.2.5:8089",
        "Sensors": {
          "IncludeKeywords": [
            "CPU Package",
            "GPU Core",
            "GPU Hot Spot",
            "GPU Memory Junction"
          ],
          "ExcludeKeywords": [
            "Distance to TjMax",
            "Core Average",
            "Core Max"
          ]
        }
      },
      {
        "MachineId": "maindesk",
        "DisplayName": "MAINDESK",
        "SourceType": "HostAgent",
        "Endpoint": "http://127.0.0.1:8089",
        "Sensors": {
          "IncludeKeywords": [
            "CPU Package",
            "GPU Core",
            "GPU Hot Spot"
          ],
          "ExcludeKeywords": []
        }
      }
    ]
  },
  "LlmUsage": {
    "RetentionDays": 30,
    "Ollama": {
      "Enabled": true,
      "Endpoint": "http://127.0.0.1:11434",
      "MachineId": "maindesk",
      "DisplayName": "MAINDESK",
      "PollIntervalSeconds": 30,
      "RequestTimeoutSeconds": 10,
      "Machines": [
        {
          "MachineId": "snd-host",
          "DisplayName": "SND-HOST",
          "Endpoint": "http://192.168.2.5:11434"
        },
        {
          "MachineId": "maindesk",
          "DisplayName": "MAINDESK",
          "Endpoint": "http://127.0.0.1:11434"
        }
      ]
    },
    "Claude": {
      "HaikuInputPer1M": 0.80,
      "HaikuOutputPer1M": 4.00,
      "SonnetInputPer1M": 3.00,
      "SonnetOutputPer1M": 15.00,
      "OpusInputPer1M": 15.00,
      "OpusOutputPer1M": 75.00
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "OllamaTelemetry.Api": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
